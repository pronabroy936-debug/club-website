# Local MongoDB:
# MONGO_URI=mongodb://localhost:27017/clubDB

# MongoDB Atlas:
# Replace USERNAME, PASSWORD, and HOST with your Atlas values.
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@HOST/clubDB?retryWrites=true&w=majority&appName=Cluster0

# This must match the database name in the URI path above.
MONGO_DB_NAME=clubDB
SECRET_KEY=change-this-to-a-long-random-value
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
UPLOAD_FOLDER=static/uploads
SOCIAL_WHATSAPP=https://wa.me/919999999999
SOCIAL_FACEBOOK=https://facebook.com/your-page
SOCIAL_YOUTUBE=https://youtube.com/@your-channel
